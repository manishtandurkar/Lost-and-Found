<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme - Material Design 3 -->
    <style name="Theme.LostAndFound" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Error color -->
        <item name="colorError">@color/error</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash theme with no action bar -->
    <style name="Theme.LostAndFound.Splash" parent="Theme.LostAndFound">
        <item name="android:windowBackground">@color/primary</item>
    </style>

    <!-- Login theme -->
    <style name="Theme.LostAndFound.Login" parent="Theme.LostAndFound">
        <item name="android:windowBackground">@color/primary</item>
    </style>

    <!-- Toolbar style -->
    <style name="Widget.LostAndFound.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/primary</item>
        <item name="titleTextColor">@color/white</item>
        <item name="navigationIconTint">@color/white</item>
    </style>

    <!-- Card style -->
    <style name="Widget.LostAndFound.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- Button style -->
    <style name="Widget.LostAndFound.Button" parent="Widget.Material3.Button">
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- TextInputLayout style -->
    <style name="Widget.LostAndFound.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
    </style>

    <!-- Lost item badge style -->
    <style name="Widget.LostAndFound.Badge.Lost">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/bg_badge_lost</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Found item badge style -->
    <style name="Widget.LostAndFound.Badge.Found">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/bg_badge_found</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Chat message styles -->
    <style name="Widget.LostAndFound.ChatBubble.Sent">
        <item name="android:background">@drawable/bg_chat_sent</item>
        <item name="android:padding">10dp</item>
    </style>

    <style name="Widget.LostAndFound.ChatBubble.Received">
        <item name="android:background">@drawable/bg_chat_received</item>
        <item name="android:padding">10dp</item>
    </style>

</resources>
